{
  "name": "postgres-SourceDB_A-sink",
  "config": {
    "connector.class": "io.confluent.connect.jdbc.JdbcSinkConnector",
    "connection.url": "jdbc:postgresql://PG_HOST:5432/SourceDB_A",
    "connection.user": "devdb",
    "connection.password": "${PG_SINK_PASSWORD}",
    "topics.regex": "SourceDB_A-source-v2\\.SourceDB_A\\..*",
    "insert.mode": "upsert",
    "delete.enabled": "true",
    "pk.mode": "record_key",
    "pk.fields": "Id",
    "auto.create": "false",
    "auto.evolve": "false",
    "table.name.format": "${topic}",
    "transforms": "unwrap,route",
    "transforms.unwrap.type": "io.debezium.transforms.ExtractNewRecordState",
    "transforms.unwrap.drop.tombstones": "false",
    "transforms.unwrap.delete.handling.mode": "rewrite",
    "transforms.route.type": "org.apache.kafka.connect.transforms.RegexRouter",
    "transforms.route.regex": "SourceDB_A-source-v2\\.SourceDB_A\\.(.+)\\.(.+)",
    "transforms.route.replacement": "$2",
    "errors.tolerance": "all",
    "errors.log.enable": "true",
    "errors.deadletterqueue.topic.name": "dlq-pg-SourceDB_A-sink",
    "batch.size": "1000",
    "consumer.override.max.poll.records": "500"
  }
}
